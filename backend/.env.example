# Gemini API key — create one free at https://aistudio.google.com (no card needed)
GOOGLE_API_KEY=

# Langfuse Cloud — create a free project at https://cloud.langfuse.com
# Project Settings -> API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Qdrant — local container in dev; Qdrant Cloud URL + API key in prod
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
